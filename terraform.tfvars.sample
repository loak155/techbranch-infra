#--------------------------------------------------------------
# General
#--------------------------------------------------------------

name   = "techbranch"
region = "ap-northeast-1"

#--------------------------------------------------------------
# ACM
#--------------------------------------------------------------

domain    = "techbranch.link"
subdomain = "api.techbranch.link"

#--------------------------------------------------------------
# RDS
#--------------------------------------------------------------

engine         = "postgres"
engine_version = "16.2"
db_instance    = "db.t3.micro"
db_name        = "techbranch"
db_username    = "postgres"
db_password    = "password"
db_port        = 5432

#--------------------------------------------------------------
# ECS Cluster
#--------------------------------------------------------------

migration_url = "file://migrations"
http_server_address = "0.0.0.0:8080"
grpc_server_address = "0.0.0.0:9090"
http_port   = 8080
grpc_port   = 9090